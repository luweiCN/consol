{
  "name": "consol",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "consol": "./packages/cli/src/main.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b tsconfig.packages.json --pretty false",
    "lint": "bunx oxlint . --deny-warnings",
    "test": "bun test --timeout 15000",
    "test:coverage": "bun test --coverage --timeout 15000",
    "test:tui": "bun test packages/tui",
    "test:i18n": "bun test packages/i18n",
    "package:build": "bun packages/packaging/src/build.ts",
    "package:smoke": "bun packages/packaging/src/smoke.ts",
    "release:check": "bun scripts/release-check.ts",
    "check:size": "bun scripts/check-size.ts",
    "check:boundaries": "bun scripts/check-boundaries.ts",
    "check:i18n": "bun scripts/check-i18n.ts",
    "check:no-inline-ui-copy": "bun scripts/check-no-inline-ui-copy.ts",
    "check:protocol": "bun scripts/check-protocol.ts",
    "check": "bun run typecheck && bun run lint && bun run check:size && bun run check:boundaries && bun run check:i18n && bun run check:no-inline-ui-copy && bun run check:protocol",
    "verify": "AGENT=1 bun run check && AGENT=1 bun test --coverage --timeout 15000"
  },
  "dependencies": {
    "@opentui/core": "0.3.1",
    "@opentui/solid": "0.3.1",
    "solid-js": "1.9.12",
    "tree-sitter-solidity": "1.2.13",
    "viem": "^2.40.0",
    "web-tree-sitter": "0.25.10",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxlint": "1.68.0",
    "typescript": "5.9.3"
  }
}
